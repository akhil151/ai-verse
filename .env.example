# Frontend Environment Variables (Not used in current setup)
# The frontend uses dynamic API URL detection

# Backend Environment Variables (Required for startup-rag/backend)
# Copy this to startup-rag/backend/.env and fill in your values

# Gemini API Key (Required)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Model Configuration
GEMINI_MODEL=gemini-1.5-pro
